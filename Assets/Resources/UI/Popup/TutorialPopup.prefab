  m_text: "\uD3C9\uD654\uB85C\uC6B4 \uC232\uC18D \uB9C8\uC744\uC758 \uC791\uC740
    \uB808\uC2A4\uD1A0\uB791.\n\uB9E4\uC77C \uBC30\uACE0\uD508 \uB3D9\uBB3C \uC190\uB2D8\uB4E4\uC774
    \uCC3E\uC544\uC635\uB2C8\uB2E4.\n\n\uD558\uC9C0\uB9CC \uC7A5\uB09C\uAFB8\uB7EC\uAE30
